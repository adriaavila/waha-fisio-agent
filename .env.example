# WAHA WhatsApp Gateway Config
WAHA_BASE_URL="http://localhost:3000"
WAHA_API_KEY="your-waha-api-key"

# Cal.com API Config (v2)
# Obtener API Key en Cal.com > Settings > Developer > API Keys
CALCOM_API_KEY="cal_live_..."
# ID del Evento/Servicio que el agente reservará (ej: 123456)
CALCOM_EVENT_TYPE_ID="123456"

# LLM Configuration
# Puedes usar OpenAI o Gemini
GEMINI_API_KEY=""
OPENAI_API_KEY=""

# Dashboard Credentials
DASHBOARD_USERNAME="admin"
DASHBOARD_PASSWORD="change-me-password"
SESSION_SECRET_KEY="generate-a-random-secret-key"
